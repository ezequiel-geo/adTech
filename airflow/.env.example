# Copy this file to .env and fill in the values.

# ── Airflow metadata DB ──────────────────────────────────────────────────────
# Used by Airflow internally (dag_run, task_instance, variable, etc.)
# Point this to a database named 'airflow' (or similar).
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://myuser:mypassword@localhost/airflow

# ── Application DB (Airflow Variables) ──────────────────────────────────────
# Used by db_writing.py to write recommendations. Point to a separate database.
AIRFLOW_VAR_DB_USER=myuser
AIRFLOW_VAR_DB_PASS=mypassword
AIRFLOW_VAR_DB_HOST=localhost
AIRFLOW_VAR_DB_NAME=adtech
